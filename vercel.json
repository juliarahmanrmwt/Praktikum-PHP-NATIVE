{
  "functions": {
    "api/*.php": {
      "runtime": "vercel-php@0.9.0"
    }
  },
  "routes": [
    { "src": "/api/proses_login", "dest": "/api/proses_login.php" },
    { "src": "/api/login", "dest": "/api/login.php" },
    { "src": "/api/(.*)", "dest": "/api/$1" },
    { "src": "/dashboard", "dest": "/api/dashboard.php" }
  ]
}